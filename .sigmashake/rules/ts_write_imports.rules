# ts_write_imports.rules — TypeScript import hygiene.
# Technology: ts | Capability: write
# Covers: wildcard imports, deep relative paths.

rule no-wildcard-imports {
  enabled true
  priority 50
  severity warning
  LOG write
  IF path GLOB "**/*.ts" AND content LINE_REGEX "import \\* as\\s+"
  OR path GLOB "**/*.tsx" AND content LINE_REGEX "import \\* as\\s+"
  MESSAGE "Wildcard imports ('import * as X') import the entire module and prevent tree-shaking. Use named imports instead."
}

rule no-deep-relative-imports {
  enabled true
  priority 40
  severity info
  LOG write
  IF path GLOB "**/*.ts" AND content LINE_REGEX "from ['\"]\\.\\.[\\/]\\.\\.[\\/]\\.\\."
  OR path GLOB "**/*.tsx" AND content LINE_REGEX "from ['\"]\\.\\.[\\/]\\.\\.[\\/]\\.\\."
  MESSAGE "Deep relative import (3+ levels) detected. Consider using path aliases (e.g., @/src/...) configured in tsconfig.json for cleaner imports."
}
