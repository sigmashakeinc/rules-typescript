# ts_write_safety.rules — TypeScript write-time safety enforcement.
# Technology: ts | Capability: write
# Covers: type suppression, any bans, eval, SQL injection, XSS, catch hygiene.

rule ban-ts-ignore {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.ts" AND content CONTAINS "@ts-ignore"
  OR path GLOB "**/*.tsx" AND content CONTAINS "@ts-ignore"
  OR path GLOB "**/*.ts" AND content CONTAINS "@ts-nocheck"
  OR path GLOB "**/*.tsx" AND content CONTAINS "@ts-nocheck"
  MESSAGE "Type suppression is banned. Fix the underlying type error instead of suppressing it with @ts-ignore or @ts-nocheck."
}

rule no-any-type {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.ts" AND content LINE_REGEX ": *any\\b"
  OR path GLOB "**/*.ts" AND content LINE_REGEX "as any\\b"
  OR path GLOB "**/*.ts" AND content LINE_REGEX "<any>"
  OR path GLOB "**/*.tsx" AND content LINE_REGEX ": *any\\b"
  OR path GLOB "**/*.tsx" AND content LINE_REGEX "as any\\b"
  MESSAGE "Do not use 'any'. Define a concrete type, interface, or generic. 'any' defeats TypeScript's type system entirely."
}

rule no-eval {
  enabled true
  priority 100
  severity error
  DENY write
  IF path GLOB "**/*.ts" AND content CONTAINS "eval("
  OR path GLOB "**/*.ts" AND content CONTAINS "new Function("
  OR path GLOB "**/*.js" AND content CONTAINS "eval("
  OR path GLOB "**/*.js" AND content CONTAINS "new Function("
  MESSAGE "eval() and new Function() are banned. They enable code injection attacks and defeat static analysis."
}

rule no-sql-interpolation {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*.ts" AND content LINE_REGEX "\\.(prepare|run|query|all|get|execute)\\(\\s*`"
  OR path GLOB "**/*.js" AND content LINE_REGEX "\\.(prepare|run|query|all|get|execute)\\(\\s*`"
  MESSAGE "Do not use template literals in SQL queries. Use parameterized statements with ? placeholders to prevent SQL injection."
}

rule ask-inner-html {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*.ts" AND content CONTAINS "innerHTML"
  OR path GLOB "**/*.tsx" AND content CONTAINS "dangerouslySetInnerHTML"
  OR path GLOB "**/*.ts" AND content CONTAINS "document.write("
  OR path GLOB "**/*.js" AND content CONTAINS "innerHTML"
  MESSAGE "Direct HTML injection detected. Verify the value is sanitized — never pass user-supplied data to innerHTML or dangerouslySetInnerHTML."
  PROMPT "Is this value fully sanitized before assignment? If it includes any user data, use a safe DOM API (textContent, createElement) instead."
}

rule catch-unknown-not-any {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*.ts" AND content LINE_REGEX "catch\\s*\\(\\s*\\w+\\s*:\\s*any\\s*\\)"
  OR path GLOB "**/*.tsx" AND content LINE_REGEX "catch\\s*\\(\\s*\\w+\\s*:\\s*any\\s*\\)"
  MESSAGE "Do not type catch variables as 'any'. Use 'unknown' and narrow the type: if (err instanceof Error) { ... }"
}

rule no-non-null-assertion {
  enabled true
  priority 75
  severity warning
  ASK write
  IF path GLOB "**/*.ts" AND content LINE_REGEX "[a-zA-Z0-9_\\]\\)]\\.!"
  OR path GLOB "**/*.ts" AND content LINE_REGEX "[a-zA-Z0-9_\\]\\)]\\[.*\\]!"
  OR path GLOB "**/*.tsx" AND content LINE_REGEX "[a-zA-Z0-9_\\]\\)]\\.!"
  MESSAGE "Non-null assertion (!) detected. Handle the null/undefined case explicitly rather than asserting it away."
  PROMPT "Can this be replaced with optional chaining (?.) or an explicit null check? Non-null assertions hide runtime errors."
}
