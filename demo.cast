[10.609426, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;174m✶\u001b[8C\u001b[38;5;216mg\u001b[2C\u001b[38;5;174mn\u001b[39m\r\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[10.709179, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;174m*\u001b[39m\r\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[10.809981, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;174m✢\u001b[7C\u001b[38;5;216ma\u001b[2C\u001b[38;5;174mi\u001b[4C\u001b[38;5;248m(thinking with medium effort)\u001b[39m\r\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[10.835369, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mI see there's a security rule preventing source\u001b[1Cmaps\u001b[1Cin\u001b[1Cthe\u001b[1Cmain\u001b[1Ctsconfig.json.\u001b[1CThis\u001b[1Cis\u001b[1Cgood\u001b[1Cpractice\u001b[1C—\u001b[1Csource\u001b[1Cmaps\u001b[1Cexpose\u001b[1CTypeScript\u001b[1Csource\u001b[1Ccode\u001b[1Cin\u001b[1Cproduction,\u001b[1Cwhich\u001b[1Ccan\u001b[1Cbe\u001b[1Ca\r\u001b[3C\u001b[1Bsecurity\u001b[1Cconcern.\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[11.044794, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  For debugging, here are the recommended approaches:                                                                                                                            \r\u001b[1B   \r\u001b[1B  \u001b[1mOption 1: Use a dev-only tsconfig override\u001b[22m (recommended)                                                                                                                       \r\u001b[2C\u001b[1B                                                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[11.21558, "o", "\u001b]0;⠂ Enable source maps in tsconfig.json\u0007"]
[11.261795, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  Create a \u001b[38;5;153mtsconfig.dev.json\u001b[39m for development:                                                                                                                                    \r\u001b[1B   \r\u001b[1B  {                                                                                                                                                                              \r\u001b[2C\u001b[1B  \u001b[36m\"extends\"\u001b[39m: \u001b[31m\"./tsconfig.json\"\u001b[39m,                           \r\r\r\n\u001b[4C\u001b[36m\"compilerOptions\"\u001b[39m:\u001b[1C{\r\r\r\n\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[11.500497, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6C\u001b[5A\u001b[36m\"sourceMap\"\u001b[39m:\u001b[1C\u001b[34mtrue\u001b[39m,\r\u001b[1B      \u001b[36m\"inlineSources\"\u001b[39m: \u001b[34mtrue\u001b[39m,                                                                                                                                                     \r\u001b[1B   \u001b[3C\u001b[36m\"declaration\"\u001b[39m:\u001b[1C\u001b[34mtrue\u001b[39m,\r\u001b[1B      \u001b[36m\"declarationMap\"\u001b[39m: \u001b[34mtrue\u001b[39m                                                                                                                                                     \r\u001b[2C\u001b[1B  }                                                       \r\r\r\n\u001b[2C}\r\r\r\n\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[11.842129, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  Then compile with: \u001b[38;5;153mtsc -p tsconfig.dev.json\u001b[39m for development.                                                                                                                   \r\u001b[1B   \r\u001b[1B  \u001b[1mOption 2: Use environment-based configuration\u001b[22m                                                                                                                                  \r\u001b[2C\u001b[1B                                                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[11.919897, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  Update your build tooling to only enable source maps when \u001b[38;5;153mNODE_ENV !== 'production'\u001b[39m.                                                                                           \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[12.155435, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  \u001b[1mOption 3: Use Node inspector\u001b[22m                                                                                                                                                   \r\u001b[1B   \r\u001b[1B  For Node.js debugging, use the native debugger:                                                                                                                                \r\u001b[2C\u001b[1B```bash                                                   \r\r\r\n\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[12.180469, "o", "\u001b]0;⠐ Enable source maps in tsconfig.json\u0007"]
[12.249229, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[6A       \r\u001b[2C\u001b[1Bnode\u001b[1C--inspect-brk\u001b[1Cdist/your-file.js\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[12.280839, "o", "\u001b]0;✳ Enable source maps in tsconfig.json\u0007"]
[12.283032, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[7Anode\u001b[1C--inspect-brk\u001b[1Cdist/your-file.js\r\u001b[2C\u001b[1B    \u001b[1C             \u001b[1C                 \r\u001b[2C\u001b[1BWhich\u001b[1Capproach\u001b[1Cwould\u001b[1Cyou\u001b[1Cprefer?\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[39m❯ \u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
